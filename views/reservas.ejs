    function renderChart() {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      const reservas = <%- JSON.stringify(reservas.map(r => ({ fecha: r.fecha }))) %>;
      const labels = [], datos = [];
      for (let i = 6; i >= 0; i--) {
        const d = new Date();
        d.setDate(d.getDate() - i);
        const fecha = d.toISOString().split('T')[0];
        labels.push(d.toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric' }));
        datos.push(reservas.filter(r => r.fecha === fecha).length);
      }
      const accent = isDark ? '#7C6FFF' : '#4F46E5';
      const gridColor = isDark ? '#1e1e2a' : '#e2e5f0';
      const tickColor = isDark ? '#6b7280' : '#9ca3af';
      window.chartInstance = new Chart(document.getElementById('grafico'), {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            data: datos,
            backgroundColor: accent + '33',
            borderColor: accent,
            borderWidth: 1,
            borderRadius: 4
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { display: false } },
          scales: {
            x: { grid: { color: gridColor }, ticks: { color: tickColor, font: { size: 11 } } },
            y: { grid: { color: gridColor }, ticks: { color: tickColor, stepSize: 1, font: { size: 11 } } }
          }
        }
      });
    }
    renderChart();
  </script>
