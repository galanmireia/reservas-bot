<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cliente — <%= cliente.nombre %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #0f0f13; color: #e2e2e2; display: flex; min-height: 100vh; }
    .sidebar { width: 240px; background: #17171f; border-right: 1px solid #2a2a35; display: flex; flex-direction: column; padding: 24px 0; position: fixed; height: 100vh; }
    .sidebar-logo { padding: 0 20px 24px; border-bottom: 1px solid #2a2a35; }
    .sidebar-logo h2 { color: #7C6FFF; font-size: 18px; }
    .sidebar-logo p { color: #666; font-size: 12px; margin-top: 2px; }
    .sidebar-menu { padding: 20px 12px; flex: 1; }
    .menu-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; color: #888; font-size: 14px; cursor: pointer; margin-bottom: 4px; text-decoration: none; }
    .menu-item:hover { background: #1e1e28; color: #e2e2e2; }
    .menu-item.active { background: #2a2560; color: #7C6FFF; }
    .sidebar-footer { padding: 16px 20px; border-top: 1px solid #2a2a35; }
    .avatar { display: flex; align-items: center; gap: 10px; }
    .avatar-circle { width: 36px; height: 36px; background: #2a2560; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #7C6FFF; font-weight: bold; font-size: 14px; }
    .avatar-info { flex: 1; }
    .avatar-name { font-size: 13px; color: #e2e2e2; }
    .avatar-rest { font-size: 11px; color: #666; }
    .logout { color: #666; font-size: 12px; text-decoration: none; display: block; margin-top: 12px; }
    .logout:hover { color: #ff6b6b; }
    .main { margin-left: 240px; flex: 1; padding: 32px; }
    .back { display: inline-flex; align-items: center; gap: 8px; color: #666; text-decoration: none; font-size: 14px; margin-bottom: 24px; }
    .back:hover { color: #e2e2e2; }
    .perfil { background: #17171f; border: 1px solid #2a2a35; border-radius: 12px; padding: 28px; margin-bottom: 28px; display: flex; align-items: center; gap: 24px; }
    .perfil-avatar { width: 72px; height: 72px; background: #2a2560; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #7C6FFF; font-size: 28px; font-weight: bold; flex-shrink: 0; }
    .perfil-info h1 { font-size: 22px; color: #e2e2e2; }
    .perfil-info p { color: #666; font-size: 14px; margin-top: 4px; }
    .perfil-stats { margin-left: auto; display: flex; gap: 24px; }
    .perfil-stat { text-align: center; }
    .perfil-stat .num { font-size: 24px; font-weight: bold; color: #7C6FFF; }
    .perfil-stat .lbl { font-size: 12px; color: #666; margin-top: 2px; }
    .seccion h2 { font-size: 16px; color: #e2e2e2; margin-bottom: 14px; }
    table { width: 100%; border-collapse: collapse; background: #17171f; border-radius: 12px; overflow: hidden; border: 1px solid #2a2a35; }
    th { background: #1e1e28; color: #888; padding: 12px 16px; text-align: left; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 500; }
    td { padding: 13px 16px; border-bottom: 1px solid #1e1e28; font-size: 14px; color: #ccc; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #1a1a24; }
    .hora-badge { background: #2a2560; color: #7C6FFF; padding: 4px 10px; border-radius: 20px; font-size: 12px; }
    .canal-badge { padding: 4px 10px; border-radius: 20px; font-size: 12px; }
    .canal-whatsapp { background: #0a2a1a; color: #4ade80; }
    .canal-llamada { background: #1a1a2a; color: #7C6FFF; }
    .canal-manual { background: #2a2020; color: #888; }
    .empty { text-align: center; padding: 40px; color: #555; font-size: 14px; }
  </style>
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-logo">
      <h2>ReservasBot</h2>
      <p><%= usuario.restaurante %></p>
    </div>
    <div class="sidebar-menu">
      <a href="/panel" class="menu-item"><span>📅</span> Reservas</a>
      <a href="/clientes" class="menu-item active"><span>👥</span> Clientes</a>
      <a href="/configuracion" class="menu-item"><span>⚙️</span> Configuración</a>
    </div>
    <div class="sidebar-footer">
      <div class="avatar">
        <div class="avatar-circle"><%= usuario.nombre.charAt(0).toUpperCase() %></div>
        <div class="avatar-info">
          <div class="avatar-name"><%= usuario.nombre %></div>
          <div class="avatar-rest"><%= usuario.email %></div>
        </div>
      </div>
      <a href="/logout" class="logout">Cerrar sesión →</a>
    </div>
  </div>

  <div class="main">
    <a href="/clientes" class="back">← Volver a clientes</a>

    <div class="perfil">
      <div class="perfil-avatar"><%= (cliente.nombre || '?').charAt(0).toUpperCase() %></div>
      <div class="perfil-info">
        <h1><%= cliente.nombre || 'Sin nombre' %></h1>
        <p><%= cliente.telefono %></p>
        <p style="margin-top:4px;">Última visita: <%= new Date(cliente.ultima_visita).toLocaleDateString('es-ES') %></p>
      </div>
      <div class="perfil-stats">
        <div class="perfil-stat">
          <div class="num"><%= reservas.length %></div>
          <div class="lbl">Reservas</div>
        </div>
        <div class="perfil-stat">
          <div class="num"><%= reservas.reduce((a, r) => a + (r.personas || 0), 0) %></div>
          <div class="lbl">Personas total</div>
        </div>
      </div>
    </div>

    <div class="seccion">
      <h2>Historial de reservas</h2>
      <table>
        <thead>
          <tr><th>#</th><th>Nombre</th><th>Fecha</th><th>Hora</th><th>Personas</th><th>Canal</th><th>Recibida</th></tr>
        </thead>
        <tbody>
          <% if (reservas.length === 0) { %>
            <tr><td colspan="7" class="empty">No hay reservas todavia</td></tr>
          <% } else { %>
            <% reservas.forEach((r, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><strong style="color:#e2e2e2"><%= r.nombre %></strong></td>
                <td><%= r.fecha %></td>
                <td><span class="hora-badge"><%= r.hora %></span></td>
                <td><%= r.personas %> personas</td>
                <td>
                  <% if (r.canal === 'whatsapp') { %>
                    <span class="canal-badge canal-whatsapp">WhatsApp</span>
                  <% } else if (r.canal === 'manual') { %>
                    <span class="canal-badge canal-manual">Presencial</span>
                  <% } else { %>
                    <span class="canal-badge canal-llamada">Llamada</span>
                  <% } %>
                </td>
                <td><%= new Date(r.creada_en).toLocaleDateString('es-ES') %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>