# Copia este archivo a .env y completá los valores.
# Para correr en modo de pruebas (sin gastar dinero), basta con TEST_MODE=true.

# === Modo pruebas ===
TEST_MODE=true
PORT=3000

# === Producción (no necesarios en TEST_MODE) ===
NODE_ENV=
SESSION_SECRET=
PUBLIC_BASE_URL=

DATABASE_URL=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=

OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_ENABLED=false
DEEPGRAM_API_KEY=
RESEND_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
